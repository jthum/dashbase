{
  "schemaVersion": 1,
  "name": "Tabs",
  "slug": "tabs",
  "category": "interactive",
  "summary": "Uses ui-tabs, tab-list, and tab-panel anatomy with ARIA roles, authored hidden panels, and a small shim for keyboard navigation and selection sync.",
  "docs": {
    "examples": [
      {
        "id": "horizontal-tabs",
        "title": "Horizontal tabs",
        "source": "./tabs.html"
      },
      {
        "id": "vertical-tabs",
        "title": "Vertical tabs",
        "source": "./tabs.html"
      }
    ]
  },
  "files": {
    "css": "./tabs.css",
    "behavior": "./tabs.js",
    "examples": [
      "./tabs.html"
    ]
  },
  "root": {
    "tag": "ui-tabs",
    "selector": "ui-tabs",
    "exportName": "Tabs"
  },
  "anatomy": [
    {
      "name": "list",
      "tag": "tab-list",
      "exportName": "TabsList",
      "selector": "tab-list[role=\"tablist\"]",
      "required": true,
      "children": [
        "tab"
      ]
    },
    {
      "name": "tab",
      "tag": "button",
      "exportName": "TabsTrigger",
      "selector": "[role=\"tab\"]",
      "required": true
    },
    {
      "name": "panel",
      "tag": "tab-panel",
      "exportName": "TabsContent",
      "selector": "tab-panel[role=\"tabpanel\"]",
      "required": true
    }
  ],
  "variants": [
    {
      "name": "vertical",
      "type": "class",
      "target": "root",
      "value": "vertical"
    },
    {
      "name": "orientation",
      "type": "attribute",
      "target": "list",
      "attribute": "aria-orientation",
      "values": [
        "horizontal",
        "vertical"
      ]
    }
  ],
  "props": [
    {
      "name": "orientation",
      "kind": "attribute",
      "target": "list",
      "attribute": "aria-orientation",
      "values": [
        "horizontal",
        "vertical"
      ]
    }
  ],
  "states": [
    {
      "name": "selected",
      "target": "tab",
      "attribute": "aria-selected",
      "values": [
        "true",
        "false"
      ]
    },
    {
      "name": "hidden",
      "target": "panel",
      "attribute": "hidden"
    },
    {
      "name": "disabled",
      "target": "tab",
      "attribute": "aria-disabled",
      "values": [
        "true",
        "false"
      ]
    }
  ],
  "accessibility": {
    "focusModel": "roving-tabindex",
    "requiredAttributes": [
      {
        "target": "tab",
        "attributes": [
          "id",
          "aria-controls",
          "aria-selected"
        ]
      },
      {
        "target": "panel",
        "attributes": [
          "id",
          "aria-labelledby"
        ]
      }
    ],
    "relationships": [
      {
        "from": "tab",
        "attribute": "aria-controls",
        "to": "panel"
      },
      {
        "from": "panel",
        "attribute": "aria-labelledby",
        "to": "tab"
      }
    ],
    "keyboardInteractions": [
      {
        "target": "tab",
        "key": "ArrowRight",
        "effect": "moves focus to the next tab in horizontal tab lists."
      },
      {
        "target": "tab",
        "key": "ArrowLeft",
        "effect": "moves focus to the previous tab in horizontal tab lists."
      },
      {
        "target": "tab",
        "key": "ArrowDown",
        "effect": "moves focus to the next tab in vertical tab lists."
      },
      {
        "target": "tab",
        "key": "ArrowUp",
        "effect": "moves focus to the previous tab in vertical tab lists."
      },
      {
        "target": "tab",
        "key": "Home",
        "effect": "moves focus to the first tab."
      },
      {
        "target": "tab",
        "key": "End",
        "effect": "moves focus to the last tab."
      },
      {
        "target": "tab",
        "key": "Enter",
        "effect": "activates the focused tab and reveals its panel."
      },
      {
        "target": "tab",
        "key": "Space",
        "effect": "activates the focused tab and reveals its panel."
      }
    ]
  },
  "events": [],
  "behavior": {
    "defaultMode": "shim-backed",
    "shim": "./tabs.js",
    "clientOnly": true,
    "domOwnership": "shim-mutates-live-state"
  },
  "imports": {
    "css": [
      "dist/components/tabs/tabs.css"
    ],
    "js": [
      "dist/components/tabs/tabs.js"
    ]
  }
}
