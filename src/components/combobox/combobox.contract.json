{
  "schemaVersion": 1,
  "name": "Combobox",
  "slug": "combobox",
  "category": "interactive",
  "summary": "Builds a searchable combobox from a semantic input plus a popover listbox, with filtering, active option movement, and selection handled by a small shim.",
  "files": {
    "css": "./combobox.css",
    "behavior": "./combobox.js",
    "examples": [
      "./combobox.html"
    ]
  },
  "root": {
    "tag": "combo-box",
    "selector": "combo-box",
    "exportName": "Combobox"
  },
  "anatomy": [
    {
      "name": "input",
      "tag": "input",
      "exportName": "ComboboxInput",
      "selector": "input[role=\"combobox\"]",
      "required": true
    },
    {
      "name": "panel",
      "tag": "popover-panel",
      "exportName": "ComboboxPanel",
      "selector": "popover-panel[popover][role=\"listbox\"]",
      "required": true,
      "children": [
        "option",
        "empty"
      ]
    },
    {
      "name": "option",
      "tag": "button",
      "exportName": "ComboboxOption",
      "selector": "button[role=\"option\"]",
      "required": true
    },
    {
      "name": "empty",
      "tag": "combobox-empty",
      "exportName": "ComboboxEmpty",
      "selector": "combobox-empty",
      "required": false
    }
  ],
  "variants": [],
  "states": [
    {
      "name": "expanded",
      "target": "input",
      "attribute": "aria-expanded",
      "values": [
        "true",
        "false"
      ]
    },
    {
      "name": "active-descendant",
      "target": "input",
      "attribute": "aria-activedescendant"
    },
    {
      "name": "selected",
      "target": "option",
      "attribute": "aria-selected",
      "values": [
        "true"
      ]
    },
    {
      "name": "hidden",
      "target": "option",
      "attribute": "hidden"
    }
  ],
  "events": [
    {
      "name": "change",
      "source": "input"
    }
  ],
  "behavior": {
    "defaultMode": "shim-backed",
    "shim": "./combobox.js"
  },
  "imports": {
    "css": [
      "dist/components/input/input.css",
      "dist/components/popover/popover.css",
      "dist/components/combobox/combobox.css"
    ],
    "js": [
      "dist/components/combobox/combobox.js"
    ]
  }
}
