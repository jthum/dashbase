{
  "name": "dashbase",
  "version": "0.1.0",
  "description": "A semantic-first CSS component library for web applications",
  "type": "module",
  "main": "dist/bundles/dashbase.css",
  "style": "dist/bundles/dashbase.css",
  "files": [
    "dist/"
  ],
  "scripts": {
    "validate:component-contracts": "bun run scripts/component-contracts.js",
    "validate:pattern-contracts": "bun run scripts/pattern-contracts.js",
    "validate:contracts": "bun run scripts/validate-examples.js",
    "validate:examples": "bun run scripts/validate-examples.js",
    "generate:pattern-manifest": "bun run scripts/generate-pattern-manifest.js",
    "generate:react": "bun run scripts/generate-react.ts",
    "validate:react": "bun run scripts/validate-react.ts",
    "build": "bun run scripts/build.js",
    "dev": "bun run scripts/build.js --watch"
  },
  "keywords": [
    "css",
    "components",
    "semantic",
    "accessibility",
    "web-standards"
  ],
  "license": "MIT"
}
